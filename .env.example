# ============================================================================
#  VARIABLES DE ENTORNO - app-firma-sedes
#  Copia este archivo como ".env.local" (desarrollo) y configura los mismos
#  valores en Railway (pestaña Variables). NUNCA subas el .env real a GitHub.
# ============================================================================

# --- MODO DE OPERACIÓN -------------------------------------------------------
# "prueba" => usa tablas de prueba (participantes_prueba, etc.) y folios PRUEBA-xx
# "real"   => usa los datos reales de los 22 participantes y folios reales
# Empieza SIEMPRE en "prueba". Cambiar a "real" es una decisión consciente.
MODO=prueba

# --- SUPABASE ----------------------------------------------------------------
# Project Settings -> API en el panel de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# La service_role key es SECRETA y solo se usa en el servidor. No la expongas.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- PROVEEDOR DE CORREO -----------------------------------------------------
# En Railway (plan de prueba) el SMTP saliente está bloqueado, así que se usa la
# API HTTPS de Brevo. Si BREVO_API_KEY está presente, se envía por Brevo; si no,
# se usa Gmail SMTP (sirve para desarrollo local).
# Brevo: crear cuenta gratis, verificar el remitente y generar una API key v3.
BREVO_API_KEY=
# Remitente (debe estar verificado en Brevo). Si se omite, se usa GMAIL_USER.
MAIL_FROM_EMAIL=tucorreo@gmail.com

# --- GMAIL (Nodemailer, respaldo para local) ---------------------------------
# Cuenta de Gmail desde la que se envían los códigos y el documento final.
GMAIL_USER=tucorreo@gmail.com
# Contraseña de APLICACIÓN de 16 caracteres (NO la contraseña normal de Gmail).
# Se genera en: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Nombre que aparece como remitente en los correos.
MAIL_FROM_NAME=Proceso opción de sede - Sala Civil Familia

# --- CONSOLA DEL MAESTRO -----------------------------------------------------
# Contraseña para entrar a /maestro. Usa una larga y única.
MAESTRO_PASSWORD=cambia-esta-clave-larga-y-unica
# Secreto para firmar la cookie de sesión del maestro (texto aleatorio largo).
SESSION_SECRET=genera-un-texto-aleatorio-de-al-menos-32-caracteres

# --- URL PÚBLICA -------------------------------------------------------------
# URL final del sitio (la que da Railway). Se usa para construir los enlaces
# de los códigos QR de trazabilidad. En desarrollo: http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
